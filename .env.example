# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# SSO (HS256 secret for signing JWTs to verticals)
AALA_SSO_SECRET=

# URLs of the five verticals (for SSO redirect / demo redeem)
URL_PRODUCT_AUTO=https://auto.aala.example
URL_PRODUCT_CRM_MEDICAL=https://crm-medical.aala.example
URL_PRODUCT_LEGAL=https://legal.aala.example
URL_PRODUCT_DENTAL=https://dental.aala.example
URL_PRODUCT_TAXI=https://taxi.aala.example

# Brand
NEXT_PUBLIC_SITE_URL=https://aala.example

# Voce CLOUD per l'albanese (Apple/Google non hanno la voce sq).
# Sorgenti in cascata: Azure → HuggingFace → Google Translate (gratis, sempre).
#
# HuggingFace (GRATIS, solo email, niente carta) — voce neurale femminile di Meta:
# huggingface.co → Settings → Access Tokens → New token (tipo "Read") → incolla qui.
HF_TOKEN=
#
# Azure Speech (qualità top, ma il free-tier F0 chiede la carta come verifica):
# portal.azure.com → risorsa "Speech" (piano F0 = 500k caratteri/mese gratis).
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=westeurope

# Resend (invio email codici demo, contatti)
# Crea account su resend.com, ottieni API key
# Per il from: usa onboarding@resend.dev all'inizio (test), poi noreply@<tuo-dominio> una volta verificato il dominio in Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=AALA <onboarding@resend.dev>
